# PostgreSQL
POSTGRES_DB=household
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional API keys
# Used in templates for map widgets
YANDEX_MAPS_API_KEY=

# Cloudinary (optional, for order photo upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Optional override URLs for external APIs
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast?latitude=55.7887&longitude=49.1221&current=temperature_2m,weather_code,wind_speed_10m
CURRENCY_API_URL=https://www.cbr-xml-daily.ru/daily_json.js
