  "item": [
    {
      "name": "1. Auth (Регистрация и вход)",
      "item": [
        {
          "name": "Регистрация клиента",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "customer_test" },
                { "key": "email", "value": "customer@test.com" },
                { "key": "password", "value": "password123" },
                { "key": "firstName", "value": "Тест" },
                { "key": "lastName", "value": "Клиентов" },
                { "key": "phone", "value": "79991234567" },
                { "key": "role", "value": "CUSTOMER" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            }
          },
          "response": []
        },
        {
          "name": "Регистрация мастера",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "master_test" },
                { "key": "email", "value": "master@test.com" },
                { "key": "password", "value": "password123" },
                { "key": "firstName", "value": "Тест" },
                { "key": "lastName", "value": "Мастеров" },
                { "key": "phone", "value": "79991234568" },
                { "key": "role", "value": "MASTER" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            }
          },
          "response": []
        },
        {
          "name": "Вход клиента",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 302 or 200', () => pm.expect(pm.response.code).to.be.oneOf([200, 302]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "customer_test" },
                { "key": "password", "value": "password123" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Specializations API",
      "item": [
        {
          "name": "GET все специализации",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/specializations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "specializations"]
            }
          },
          "response": []
        },
        {
          "name": "POST создать специализацию",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const spec = pm.response.json();",
                  "    pm.collectionVariables.set('specializationId', spec.id);",
                  "}",
                  "pm.test('Status 201 or 403', () => pm.expect(pm.response.code).to.be.oneOf([201, 403]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Сантехник\",\n  \"description\": \"Ремонт и установка сантехники\",\n  \"basePrice\": 1500,\n  \"weatherDependent\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/specializations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "specializations"]
            }
          },
          "response": []
        },
        {
          "name": "GET специализация по ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/specializations/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "specializations", "1"]
            }
          },
          "response": []
        },
        {
          "name": "PUT обновить специализацию",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Сантехник (обновлено)\",\n  \"description\": \"Ремонт сантехники + замена труб\",\n  \"basePrice\": 2000,\n  \"weatherDependent\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/specializations/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "specializations", "1"]
            }
          },
          "response": []
        },
        {
          "name": "DELETE специализацию",
          "request": {
            "method": "DELETE",
            "header": [],
