{
  "info": {
    "name": "ДомБыт API",
    "description": "Коллекция тестов для семестровой работы Spring Boot",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "household-services-api"
