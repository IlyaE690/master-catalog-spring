{
  "info": {
    "name": "ДомБыт API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "household-services-api-v4"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "csrfToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "JSESSIONID",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "specializationId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Аутентификация",
      "item": [
        {
          "name": "01 - Получить CSRF токен",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const html = pm.response.text();",
                  "const match = html.match(/name=\"_csrf\" value=\"([^\"]+)\"/);",
                  "if (match) {",
                  "    pm.collectionVariables.set('csrfToken', match[1]);",
                  "    console.log('CSRF Token:', match[1]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          },
          "response": []
        },
        {
          "name": "02 - Регистрация клиента",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "postman_client" },
                { "key": "email", "value": "postman@client.com" },
                { "key": "password", "value": "password123" },
                { "key": "firstName", "value": "Postman" },
                { "key": "lastName", "value": "Client" },
                { "key": "phone", "value": "79001112233" },
                { "key": "role", "value": "CUSTOMER" },
                { "key": "_csrf", "value": "{{csrfToken}}" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            }
          },
          "response": []
        },
        {
          "name": "03 - Регистрация мастера",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "postman_master" },
                { "key": "email", "value": "postman@master.com" },
                { "key": "password", "value": "password123" },
                { "key": "firstName", "value": "Postman" },
                { "key": "lastName", "value": "Master" },
                { "key": "phone", "value": "79004445566" },
                { "key": "role", "value": "MASTER" },
                { "key": "specializationIds", "value": "1" },
                { "key": "specializationIds", "value": "2" },
                { "key": "_csrf", "value": "{{csrfToken}}" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            }
          },
          "response": []
        },
        {
          "name": "04 - Вход в систему",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 302 or 200', () => pm.expect(pm.response.code).to.be.oneOf([200, 302]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "postman_client" },
                { "key": "password", "value": "password123" },
                { "key": "_csrf", "value": "{{csrfToken}}" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. API Запросы",
      "item": [
        {
          "name": "GET все специализации",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.test('Response is array', () => Array.isArray(data));",
                  "if (data.length > 0 && !pm.collectionVariables.get('specializationId')) {",
                  "    pm.collectionVariables.set('specializationId', data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/specializations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "specializations"]
            }
          },
          "response": []
        },
        {
          "name": "GET проверить username",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/validate/username?username=testuser",
              "host": ["{{baseUrl}}"],
              "path": ["api", "validate", "username"],
              "query": [
                { "key": "username", "value": "testuser" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST AI подбор мастера",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issueDescription\": \"Капает вода из крана\",\n  \"minRating\": 4.5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/ai-suggest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "ai-suggest"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Тесты ошибок",
      "item": [
        {
          "name": "GET несуществующий маршрут (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/non-existent-page",
              "host": ["{{baseUrl}}"],
              "path": ["non-existent-page"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}